# Required for POST /analyze — create key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional OpenAI for GPT-4o instead/alongside:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# LLM_PROVIDER=openai

# Embeddings: auto uses OpenAI vectors only if OPENAI_API_KEY is set; else local MiniLM
# EMBEDDING_PROVIDER=local
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
